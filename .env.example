# Copy to .env and fill in. NEVER commit your real .env.
# Moxie auto-loads .env from the current directory or ~/.moxie.

# --- The brain (bring your own key) ---
# Your own Anthropic API key (console.anthropic.com). Moxie pays nothing; you do.
# Enables `moxie ask` and free-text questions over Telegram.
MOXIE_API_KEY=
# MOXIE_MODEL=claude-sonnet-5      # default
# Or run rules-only / fully offline and leave the key blank:
MOXIE_OFFLINE=false

# --- Telegram channel (optional) ---
# 1. Chat with @BotFather in Telegram -> /newbot -> copy the token here.
# 2. Run `moxie telegram`, message your bot; it replies with your chat id.
# 3. Put that id below and restart. The bot answers YOUR chat only.
TELEGRAM_BOT_TOKEN=
MOXIE_TELEGRAM_CHAT_ID=
# MOXIE_SCAN_HOUR=9                # daily scan hour for the Telegram loop

# --- Where Moxie stores data (defaults to ~/.moxie) ---
# MOXIE_HOME=

# --- Open banking (bring-your-own provider credentials) — stubbed for now ---
# TrueLayer planned first; see docs/HOW_IT_WORKS.md.
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=

# --- Skills directory ---
# MOXIE_SKILLS=./skills
