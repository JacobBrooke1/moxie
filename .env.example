# Copy to .env and fill in. NEVER commit your real .env.

# --- LLM (bring your own key) ---
# Your own API key for a hosted model (OpenAI/Anthropic/etc.). Moxie pays nothing; you do.
MOXIE_API_KEY=
# Or run fully offline with a local model and leave the key blank:
MOXIE_OFFLINE=false
# MOXIE_MODEL=gpt-4o-mini        # hosted example
# MOXIE_MODEL=ollama:llama3.1    # local/offline example

# --- Where Moxie stores data (defaults to ~/.moxie) ---
# MOXIE_HOME=

# --- Plaid (read-only account data) — optional, stubbed for now ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Skills directory ---
# MOXIE_SKILLS=./skills
